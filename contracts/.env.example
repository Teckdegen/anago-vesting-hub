# Deployer private key (NEVER commit the real one)
PRIVATE_KEY=0xabc123...

# RPC endpoints (override if you use a custom provider)
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
MONAD_MAINNET_RPC=https://rpc.monad.xyz

# Block explorer key (Monad testnet — leave as no-key if not required)
MONAD_EXPLORER_API_KEY=no-key
